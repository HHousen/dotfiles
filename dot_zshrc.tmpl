# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Disable zsh history persistence; Atuin manages command history.
HISTSIZE=0
SAVEHIST=0
unset HISTFILE

zstyle ':plugin:ez-compinit' 'compstyle' 'zshzoo'
source ${ZDOTDIR:-$HOME}/.antidote/antidote.zsh

# Needed for git plugin, which mostly just adds useful aliases
function git_current_branch() {
  command git symbolic-ref --quiet --short HEAD 2>/dev/null ||
    command git rev-parse --short HEAD 2>/dev/null
}

antidote load

bindkey '^[[1;5D' backward-word
bindkey '^[[1;5C' forward-word

# Aliases
alias rcat="$(which cat)"
alias cat="$(which bat)"
alias ls="lsd"
alias cd="z"
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

alias claude='echo "Use cwork or chome"'
alias codex='echo "Use xwork or xhome"'
alias cwork='CLAUDE_CONFIG_DIR=~/.claude-work command claude'
alias chome='CLAUDE_CONFIG_DIR=~/.claude-personal command claude'
alias xwork='CODEX_HOME=~/.codex-work command codex'
alias xhome='CODEX_HOME=~/.codex-personal command codex'
{{ if and (hasKey . "ai_work_short_cut_path") (ne .ai_work_short_cut_path "") -}}
alias cwsc='cd {{ .ai_work_short_cut_path | quote }} && cwork'
alias xwsc='cd {{ .ai_work_short_cut_path | quote }} && xwork'
{{ end }}
eval "$(zoxide init zsh)"
eval "$(atuin init zsh)"
eval "$(mise activate zsh)"

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
